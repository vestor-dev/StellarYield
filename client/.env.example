# Public frontend configuration. Vite exposes only variables prefixed with VITE_.
# Copy to client/.env.local for local development. Do not commit real secrets.

# Backend API base URL. Defaults to http://localhost:3001 when omitted.
VITE_API_BASE_URL=http://localhost:3001

# Soroban network configuration.
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_CONTRACT_ID=
VITE_ZAP_CONTRACT_ID=
VITE_VESTING_CONTRACT_ID=

# Zap asset metadata. Keep contract IDs public; never put private keys here.
VITE_ZAP_METADATA_FROM_API=true
VITE_ZAP_ASSETS_JSON=
VITE_XLM_SAC_CONTRACT_ID=
VITE_USDC_SAC_CONTRACT_ID=
VITE_AQUA_SAC_CONTRACT_ID=
VITE_VAULT_TOKEN_CONTRACT_ID=
VITE_VAULT_TOKEN_DECIMALS=7
VITE_VAULT_TOKEN_SYMBOL=USDC
VITE_VAULT_CONTRACT_ID=

# Optional public integration settings (safe to expose in browser).
VITE_APP_URL=https://stellaryield.vercel.app
VITE_OFFRAMP_BASE_URL=https://api.moonpay.com
VITE_GOOGLE_CLIENT_ID=

# ⚠️  Server-side secrets — DO NOT prefix with VITE_
# These are loaded by the Express backend and NEVER sent to the browser.
# Set them in server/.env (not client/.env).
# OFFRAMP_API_KEY=
# GOOGLE_CLIENT_SECRET=
